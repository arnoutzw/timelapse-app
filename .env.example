# Ring Configuration
RING_TOKEN_PATH=./data/ring-token.json
RING_CAMERA_NAME=                 # Optional: camera name filter (default: first camera)
CAPTURE_METHOD=auto               # auto, snapshot_api, or live_view

# Timelapse Configuration (for CLI timelapse.sh)
CAPTURE_INTERVAL=30               # Seconds between snapshots (minimum 15)
TOTAL_DURATION=3600               # Total capture duration in seconds
FRAMERATE=30                      # Output video framerate

# Server
PORT=3000
